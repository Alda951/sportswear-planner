generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          UserRole  @default(MEMBER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      Session[]
  accounts      Account[]
  tasks         Task[]    @relation("AssignedTasks")
  createdTasks  Task[]    @relation("CreatedTasks")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Product {
  id          String        @id @default(cuid())
  name        String
  description String?
  category    String?
  sport       String?       // e.g. Hockey, Flag Football, Football, All
  status      ProductStatus @default(IN_DEVELOPMENT)
  color       String        @default("#f97316") // derived from category
  emoji       String        @default("")
  targetDate  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  slackImport Boolean       @default(false)

  tasks       Task[]

  @@map("products")
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?    @db.Text
  status      TaskStatus @default(TODO)
  priority    Priority   @default(MEDIUM)
  dueDate     DateTime?
  startDate   DateTime?
  position    Int        @default(0) // for kanban ordering

  productId   String
  product     Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  assigneeId  String?
  assignee    User?      @relation("AssignedTasks", fields: [assigneeId], references: [id])

  createdById String?
  createdBy   User?      @relation("CreatedTasks", fields: [createdById], references: [id])

  slackMessageTs  String?  // Slack message timestamp (ts) for two-way sync
  slackChannelId  String?
  slackThreadTs   String?
  slackSynced     Boolean  @default(false)

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([productId])
  @@index([status])
  @@index([assigneeId])
  @@index([slackMessageTs])
  @@map("tasks")
}

model SlackMessage {
  id         String   @id @default(cuid())
  ts         String   @unique  // Slack message timestamp
  channelId  String
  userId     String?
  username   String?
  text       String   @db.Text
  taskId     String?  // linked task if converted
  isTask     Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([channelId])
  @@map("slack_messages")
}

enum UserRole {
  ADMIN
  MEMBER
  VIEWER
}

enum ProductStatus {
  IN_DEVELOPMENT
  IN_MANUFACTURE
  IN_REVIEW
  LAUNCHED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}
