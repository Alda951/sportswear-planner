# ─────────────────────────────────────────
# Neon Postgres (get from console.neon.tech)
# ─────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
# DIRECT_URL is the same as DATABASE_URL for Neon — used by Prisma migrations
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# ─────────────────────────────────────────
# NextAuth (generate with: openssl rand -base64 32)
# ─────────────────────────────────────────
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"   # change to https://your-app.vercel.app in prod

# ─────────────────────────────────────────
# Slack (create a Slack App at api.slack.com)
# Required scopes: channels:history, channels:read, chat:write, users:read
# ─────────────────────────────────────────
SLACK_BOT_TOKEN="xoxb-your-bot-token"
SLACK_SIGNING_SECRET="your-signing-secret"
SLACK_CHANNEL_NAME="product-development"
